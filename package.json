{
  "name": "url-preview-api",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node node_modules/puppeteer/install.mjs",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src/",
    "test": "node --test",
    "setup:appwrite": "node --env-file=.env src/scripts/setupAppwrite.js",
    "showFiles": "find src -type f -name '*.js' | sort"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "glob": "^13.0.6",
    "node-appwrite": "^24.0.0",
    "open-graph-scraper": "^6.11.0",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
